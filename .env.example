# UGC Swap Studio provider configuration
# Never commit real keys. Keep provider secrets in your local shell, keychain, or deployment secret store.

VITE_STUDIO_DEFAULT_PROVIDER=mock-local

# Live/local adapter credentials should be stored in macOS Keychain service "CopyTok"
# or in a private shell environment. Do not commit real values.
#
# security add-generic-password -U -s CopyTok -a FAL_KEY -w "<secret>"
# security add-generic-password -U -s CopyTok -a APIFY_TOKEN -w "<secret>"
#
# Direct video providers:
# KLING_API_KEY=
# KLING_CREATE_URL=
# KLING_STATUS_URL_TEMPLATE=
# SEEDANCE_API_KEY=
# SEEDANCE_API_BASE_URL=
# SEEDANCE_CREATE_URL=
# SEEDANCE_STATUS_URL_TEMPLATE=
# BYTEPLUS_API_KEY=
#
# Still-image provider:
# OPENAI_API_KEY=
#
# Other adapter candidates:
# HEYGEN_API_KEY=
# PIXVERSE_API_KEY=
# REPLICATE_API_TOKEN=
# RUNWAY_API_KEY=

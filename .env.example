# UGC Swap Studio provider configuration
# Never commit real keys. Keep provider secrets in your local shell, keychain, or deployment secret store.

VITE_STUDIO_DEFAULT_PROVIDER=mock-local

# Live/local adapter credentials should be stored in macOS Keychain service "CopyTok"
# or in a private shell environment. Do not commit real values.
#
# security add-generic-password -U -s CopyTok -a FAL_KEY -w "<secret>"
# security add-generic-password -U -s CopyTok -a APIFY_TOKEN -w "<secret>"
#
# Direct video providers:
# Kling direct uses the official Kling access-key / secret-key pair. The app also
# accepts KLINGAI_ACCESS_KEY / KLINGAI_SECRET_KEY aliases for SDK compatibility,
# or KLING_API_KEY when stored as ACCESS_KEY:SECRET_KEY.
# KLING_ACCESS_KEY=
# KLING_SECRET_KEY=
# KLING_API_KEY=
# KLING_MODEL=kling-v3.0-motion-control
# KLING_BASE_URL=
#
# Seedance direct uses BytePlus ModelArk. ARK_API_KEY is the preferred name.
# SEEDANCE_MODEL=dreamina-seedance-2-0-260128
# ARK_API_KEY=
# SEEDANCE_API_KEY=
# SEEDANCE_API_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# BYTEPLUS_API_KEY=
#
# Still-image provider:
# OPENAI_API_KEY=
#
# Other adapter candidates:
# HEYGEN_API_KEY=
# PIXVERSE_API_KEY=
# REPLICATE_API_TOKEN=
# RUNWAY_API_KEY=
